{
  "name": "LHM (CUDA 12.1)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  "remoteUser": "root",

  "runArgs": [
    "--gpus=all",
    "--shm-size=16g",
    "--security-opt=label=disable"
  ],

  "workspaceFolder": "/workspaces/LHM",

  "containerEnv": {
    "CUDA_HOME": "/usr/local/cuda",
    "NVIDIA_VISIBLE_DEVICES": "all",
    "NVIDIA_DRIVER_CAPABILITIES": "compute,utility,graphics"
  },

  "postCreateCommand": "nvcc --version && python -c 'import torch; print(torch.cuda.is_available())'",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}